# =============================================================================
# Django Configuration
# =============================================================================
DJANGO_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database
# =============================================================================
# Development (SQLite - no config needed)
# Production (PostgreSQL via Railway)
DATABASE_URL=postgresql://user:password@localhost:5432/landinglawyer

# =============================================================================
# AWS S3 Configuration (for PDF storage)
# =============================================================================
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=landinglawyer-reports-prod
AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# Google Calendar API
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# =============================================================================
# Brevo Email Service (NO SMS - only email)
# =============================================================================
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@landinglawyer.com
BREVO_SENDER_NAME=landingLawyer

# =============================================================================
# Celery & Redis (Task Queue)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# CORS Configuration (Frontend URLs)
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,landinglawyer-production.up.railway.app

# =============================================================================
# Token System Configuration
# =============================================================================
TOKEN_DEFAULT_EXPIRY_HOURS=24
TOKEN_MAX_USES=1

# =============================================================================
# Frontend Configuration (for reference)
# =============================================================================
# Add to frontend/.env.example
# VITE_API_URL=http://localhost:8000/api
# VITE_API_URL_PRODUCTION=https://your-railway-domain.up.railway.app/api
